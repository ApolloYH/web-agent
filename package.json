{
  "name": "web-agent",
  "private": true,
  "version": "0.1.0",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "office:setup": "node scripts/setup-onlyoffice-runtime.mjs",
    "office:compress": "node scripts/precompress-assets.mjs",
    "rag:start": "node scripts/start-rag-engines.mjs",
    "build": "pnpm --filter @apolloyh/apollo-agent build && tsc -b && vite build && node scripts/precompress-assets.mjs && pnpm build:server && pnpm build:extension",
    "build:server": "tsc -p tsconfig.server.json",
    "build:extension": "tsc -p browser-extension/tsconfig.json && vite build --config browser-extension/vite.config.ts --mode extension-content && vite build --config browser-extension/vite.config.ts --mode extension-background",
    "backup": "node scripts/backup-production.mjs",
    "test": "pnpm exec tsx --test src/lib/graphPalette.test.ts && pnpm build:server && node --test server-dist/server/*.test.js scripts/*.test.mjs",
    "test:concurrency": "pnpm build:server && node --test server-dist/server/concurrency.test.js",
    "start": "node server-dist/server/production.js",
    "preview": "vite preview --host 127.0.0.1",
    "check:open-design": "node scripts/check-open-design-upstream.mjs"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@agentbridges-ai/onlyoffice-browser": "0.3.27",
    "@apolloyh/apollo-agent": "workspace:*",
    "@larksuiteoapi/node-sdk": "1.71.1",
    "@page-agent/page-controller": "1.12.1",
    "@react-sigma/core": "^5.0.6",
    "@wecom/aibot-node-sdk": "1.0.7",
    "ai-motion": "0.4.8",
    "dingtalk-stream": "2.1.6-beta.1",
    "docx-preview": "^0.4.0",
    "fflate": "0.8.2",
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "highlight.js": "^11.10.0",
    "pdfjs-dist": "5.4.624",
    "qrcode": "1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "sigma": "^3.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/chrome": "0.2.2",
    "@types/node": "^26.1.1",
    "@types/qrcode": "1.5.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.2"
  }
}
