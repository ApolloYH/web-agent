# Apollo Web Agent 环境变量示例
# 复制为 .env 后填写真实值：cp .env.example .env
# .env 已被 Git 忽略。不要提交 API Key、邀请码或其他密钥。

# ── 大模型：OpenAI / OpenAI-compatible（必填）──────────────────────────────
# OpenAI 官方和任何兼容 /v1/chat/completions 的服务都使用这一组变量。
APOLLO_LLM_PROTOCOL=openai
OPENAI_API_KEY=replace_with_your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 单次回复最大 token 数；不填时普通 OpenAI 模型默认 4096。
OPENAI_MAX_TOKENS=4096
# 请求超时，单位毫秒。
OPENAI_TIMEOUT_MS=300000
# 可选：一般无需填写。Apollo 会为 o1/o3/o4、gpt-5 系列自动使用
# max_completion_tokens，其他模型自动使用 max_tokens。
# OPENAI_MAX_TOKENS_PARAM=max_tokens

# 使用第三方 OpenAI-compatible 服务时通常只需替换这三项：
# OPENAI_API_KEY=your_provider_api_key
# OPENAI_BASE_URL=https://your-provider.example/v1
# OPENAI_MODEL=your-model-name

# ── 网络搜索（可选）────────────────────────────────────────────────────────
# 未配置时 Agent 的 Exa 网络搜索工具不可用，不影响普通对话。
EXA_API_KEY=

# ── LangHub 业务智能体（可选，仅后端读取）─────────────────────────────────
NOUMI_API_BASE=https://www.langhub.cn/api/external/v1
NOUMI_API_KEY=

# LangHub 各业务智能体的项目 ID。
LANGHUB_PROJECT_RISK_CARD=
LANGHUB_PROJECT_SUPERVISION_NOTICE=
LANGHUB_PROJECT_SUPERVISION_LOG=
LANGHUB_PROJECT_SUPERVISION_DOCUMENT=
LANGHUB_PROJECT_HAZARD=
LANGHUB_PROJECT_PLAN_REVIEW=
LANGHUB_PROJECT_DRAWING_COMPARE=

# ── 工标库 LangCore（可选）─────────────────────────────────────────────────
LANGCORE_API_KEY=

# ── Web 登录与权限（生产环境必填）─────────────────────────────────────────
# 注册邀请码建议使用至少 32 位随机字符串；留空将关闭邀请码注册。
WEB_REGISTRATION_INVITE=replace_with_a_long_random_invite
# 与该用户名匹配的账号拥有管理员权限。
WEB_ADMIN_USERNAME=admin
# 无容器/系统级沙箱时必须保持 false。
WEB_ALLOW_UNRESTRICTED=false
# 仅列出会覆盖 X-Real-IP/X-Forwarded-For 的直属反向代理地址；留空则忽略这些请求头。
# 本机 Nginx/FRP 代理通常填写：127.0.0.1,::1
WEB_TRUSTED_PROXIES=

# Agent 并发保护：单节点同时运行任务总数，以及单账号同时运行任务数。
# 超过限制时返回 HTTP 429，避免突发请求耗尽内存。
WEB_MAX_CONCURRENT_RUNS=8
WEB_MAX_RUNS_PER_USER=3
# 低于该可用空间时健康检查返回 503，并拒绝新文件写入（默认 512MB）。
WEB_MIN_FREE_DISK_BYTES=536870912
# 每个账号的服务器工作区上限（默认 2GB，0 表示关闭配额）。
WEB_USER_STORAGE_QUOTA_BYTES=2147483648
# 对话上传的临时文件保留天数；文件库产物不受影响。
WEB_UPLOAD_RETENTION_DAYS=7
# 生产数据快照保留天数。
WEB_BACKUP_RETENTION_DAYS=14

# ── Apollo 托管浏览器（可选）──────────────────────────────────────────────
# 未配置时不会注册 browser_managed_task，不影响用户本地 Chrome 扩展。
APOLLO_BROWSER_WORKER_URL=
APOLLO_BROWSER_WORKER_TOKEN=
# Worker 使用下方 Anthropic-compatible 配置；可单独覆盖模型。
BROWSER_WORKER_MODEL=
# 实时预览抓帧间隔，默认约 6.7 FPS。
BROWSER_WORKER_FRAME_INTERVAL=0.15

# ── Apollo 轻站点（可选）─────────────────────────────────────────────────
# 必须使用与主站不同的域名，避免用户生成的脚本读取 Apollo 登录态。
APOLLO_SITES_BASE_URL=https://sites.example.com

# ── 服务监听（可选）────────────────────────────────────────────────────────
# 主站与独立 Office Host 的本机监听端口。
PORT=9130
OFFICE_HOST_PORT=5174

# ── Anthropic-compatible 备选配置 ──────────────────────────────────────────
# 若改用 Anthropic 协议，请注释上面的 OPENAI 配置，并启用以下变量：
# APOLLO_LLM_PROTOCOL=anthropic
# ANTHROPIC_AUTH_TOKEN=replace_with_your_anthropic_api_key
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-haiku-4-5
# ANTHROPIC_MAX_TOKENS=4096
# ANTHROPIC_TIMEOUT_MS=300000
# ANTHROPIC_CACHE_TTL=5m
